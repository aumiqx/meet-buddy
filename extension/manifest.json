{
  "manifest_version": 3,
  "name": "Meet Buddy",
  "version": "1.0.0",
  "description": "Real-time meeting intelligence — captures transcripts & screenshots, syncs to GitHub, feeds your AI dev workflow.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "offscreen"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/meet-scraper.js"],
      "css": ["content/meet-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Meet Buddy"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
